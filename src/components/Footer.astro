---
const year = new Date().getFullYear();
---

<footer>
  <div class="inner">
    <span class="label">© {year} Adefila Abdulmuiz</span>
    <span class="label status">
      <span class="dot" aria-hidden="true"></span> lagos, nigeria · open to work
    </span>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid var(--border);
    margin-top: var(--space-7);
  }

  .inner {
    max-width: var(--max-width);
    margin-inline: auto;
    padding: var(--space-4) var(--gutter);
    display: flex;
    justify-content: space-between;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .status {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
  }

  .dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 6px var(--accent);
  }
</style>
